# RAG2riches Environment Variables

# Add your actual keys to a .env file (not committed to git).
# DO NOT commit your .env file to version control.

# ============================================================================
# EMBEDDING PROVIDERS (Required for v0.2+)
# ============================================================================

# OpenAI Embeddings
OPENAI_API_KEY=sk-...

# Google Gemini
GEMINI_API_KEY=...

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI Embeddings
VOYAGE_API_KEY=...

# ============================================================================
# LLM PROVIDERS (Required for v0.2+)
# ============================================================================

# OpenAI (GPT models)
OPENAI_API_KEY=sk-...

# Google Gemini
GEMINI_API_KEY=...

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (if using local models)
# OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# VECTOR STORE (Optional, LanceDB uses local file storage by default)
# ============================================================================

# LanceDB storage path (defaults to ./rag2riches_store if not set)
LANCEDB_PATH=./rag2riches_store

# ============================================================================
# LOGGING (Optional)
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (optional, logs to console if not set)
LOG_FILE=./rag2riches.log

# ============================================================================
# APPLICATION SETTINGS (Optional)
# ============================================================================

# Embedding batch size (speeds up processing)
EMBEDDING_BATCH_SIZE=32

# LLM generation timeout in seconds
GENERATION_TIMEOUT=300

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================

# 1. Copy this file to .env
#    cp .env.example .env

# 2. Add your actual API keys to .env
#    OPENAI_API_KEY=sk-your-actual-key
#    etc.

# 3. .env is automatically loaded when you import rag2riches
#    (via python-dotenv in rag2riches/logging_utils.py)

# 4. Never commit .env to git (already in .gitignore)

# ============================================================================
# PROVIDER SETUP
# ============================================================================

# OpenAI:
#   1. Create account at https://platform.openai.com
#   2. Generate API key at https://platform.openai.com/api/keys
#   3. Set OPENAI_API_KEY
#   4. Use models like: gpt-4o, gpt-4o-mini, text-embedding-3-small

# Google Gemini:
#   1. Create account at https://makersuite.google.com/app/apikey
#   2. Generate API key
#   3. Set GEMINI_API_KEY
#   4. Use models like: gemini-pro

# Anthropic Claude:
#   1. Create account at https://console.anthropic.com
#   2. Generate API key
#   3. Set ANTHROPIC_API_KEY
#   4. Use models like: claude-3-haiku, claude-3-sonnet

# Voyage AI:
#   1. Create account at https://www.voyageai.com
#   2. Generate API key
#   3. Set VOYAGE_API_KEY
#   4. Use models like: voyage-3, voyage-3-lite

# Ollama (local):
#   1. Install Ollama from https://ollama.ai
#   2. Run: ollama run llama2
#   3. Models available locally, no API key needed
